{
  "name": "clientpulse",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run start:dev --workspace server",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspace server",
    "typecheck": "npm run typecheck --workspaces",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "prisma:migrate": "npm run prisma:migrate --workspace server",
    "prisma:deploy": "npm run prisma:deploy --workspace server",
    "seed": "npm run seed --workspace server",
    "seed:demo": "npm run seed:demo --workspace server"
  },
  "engines": {
    "node": ">=22"
  }
}
